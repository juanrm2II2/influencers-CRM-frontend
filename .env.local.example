# Copy this file to .env.local and fill in your values

# URL of your Express backend (Railway deployment or localhost for development)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth – the backend /api/auth/login endpoint should return
# { user: { id, email, name, role }, accessToken, refreshToken }
# No additional frontend auth config is required; the API URL above is used.

# ─── Web3 / Token Sale ───────────────────────────────────────────────────────

# WalletConnect Cloud project ID (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Contract addresses (deployed on your target chain)
NEXT_PUBLIC_TOKEN_SALE_ADDRESS=
NEXT_PUBLIC_VESTING_ADDRESS=

# Optional: per-chain RPC URL overrides (default: public RPCs)
# NEXT_PUBLIC_CHAIN_RPC_URL_MAINNET=
# NEXT_PUBLIC_CHAIN_RPC_URL_POLYGON=
# NEXT_PUBLIC_CHAIN_RPC_URL_ARBITRUM=
# NEXT_PUBLIC_CHAIN_RPC_URL_BASE=
# NEXT_PUBLIC_CHAIN_RPC_URL_SEPOLIA=

# ─── KYC / Identity Verification ─────────────────────────────────────────────

# The backend handles SumSub API communication.  These frontend-side
# variables are optional and only used if the backend is configured to
# return them.  No SumSub secret keys should ever appear here.
# NEXT_PUBLIC_KYC_ENABLED=true
