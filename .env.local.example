# Copy this file to .env.local and fill in your values

# URL of your Express backend (Railway deployment or localhost for development)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth – the backend /api/auth/login endpoint should return
# { user: { id, email, name, role }, accessToken, refreshToken }
# No additional frontend auth config is required; the API URL above is used.

# ─── Web3 / Token Sale ───────────────────────────────────────────────────────

# WalletConnect Cloud project ID (https://cloud.walletconnect.com)
# Required – obtain from your own WalletConnect Cloud account; do NOT commit real IDs here.
#
# Rotation procedure (audit M-01):
#   1. Generate a new project ID in the WalletConnect Cloud dashboard.
#   2. Update NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID in every deployment
#      target (Vercel / Railway / .env.local) and redeploy. Builds will
#      fail at module load if the env var is missing — verify the new
#      value is in place BEFORE deleting the old one.
#   3. Delete the previous ID in the WalletConnect Cloud dashboard.
#   4. Run `git log -p -S<previous-project-id>` to confirm no historical
#      commit ever leaked the value; rotate immediately + open an
#      incident if a hit is found. We recommend installing `gitleaks`
#      as a pre-commit hook to make this an automated check.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Contract addresses (deployed on your target chain)
NEXT_PUBLIC_TOKEN_SALE_ADDRESS=
NEXT_PUBLIC_VESTING_ADDRESS=

# Expected chain ID for write transactions (defaults to 1 = Ethereum mainnet)
# Set to 11155111 for Sepolia testnet, 137 for Polygon, etc.
NEXT_PUBLIC_EXPECTED_CHAIN_ID=

# ─── Contribution bounds (audit H-02) ────────────────────────────────────────
# Optional decimal-string overrides for the per-tx contribution range.
# If unset, defaults are 0.01 ETH (min), 10 ETH (soft cap that triggers
# UI confirmation), and 100 ETH (hard max). Strings, not numbers, so
# 18-decimal precision is preserved.
# NEXT_PUBLIC_MIN_CONTRIBUTION_ETH=0.01
# NEXT_PUBLIC_SOFT_CAP_CONTRIBUTION_ETH=10
# NEXT_PUBLIC_MAX_CONTRIBUTION_ETH=100

# Optional: per-chain RPC URL overrides (default: public RPCs)
# NEXT_PUBLIC_CHAIN_RPC_URL_MAINNET=
# NEXT_PUBLIC_CHAIN_RPC_URL_POLYGON=
# NEXT_PUBLIC_CHAIN_RPC_URL_ARBITRUM=
# NEXT_PUBLIC_CHAIN_RPC_URL_BASE=
# NEXT_PUBLIC_CHAIN_RPC_URL_SEPOLIA=

# ─── KYC / Identity Verification ─────────────────────────────────────────────

# The backend handles SumSub API communication.  These frontend-side
# variables are optional and only used if the backend is configured to
# return them.  No SumSub secret keys should ever appear here.
# NEXT_PUBLIC_KYC_ENABLED=true
